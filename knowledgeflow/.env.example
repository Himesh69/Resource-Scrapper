# ============================================================
# KnowledgeFlow — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below.
# 3. NEVER commit .env to version control!
# ============================================================

# ── Telegram ────────────────────────────────────────────────
# Steps:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot and follow the prompts
#   3. Paste the token you receive here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── OpenRouter ───────────────────────────────────────────────
# Get your API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://github.com/knowledgeflow
OPENROUTER_APP_NAME=KnowledgeFlow

# ── Notion ───────────────────────────────────────────────────
# Steps:
#   1. Go to https://www.notion.so/my-integrations
#   2. Click "+ New integration", give it a name (e.g. KnowledgeFlow)
#   3. Copy the "Internal Integration Token" here
#   4. Run:  python scripts/setup_notion.py
#      This creates the 5 databases and prints the IDs for you.
NOTION_TOKEN=secret_your_notion_integration_token_here

# These are filled in automatically by: python scripts/setup_notion.py
NOTION_SOURCES_DB_ID=
NOTION_RESOURCES_DB_ID=
NOTION_CATEGORIES_DB_ID=
NOTION_CREATORS_DB_ID=
NOTION_KNOWLEDGE_DB_ID=

# ── App Behaviour ────────────────────────────────────────────
MAX_CONCURRENT_JOBS=3
KEEP_CACHE=false
LOG_LEVEL=INFO
CACHE_DIR=.cache
